generator client {
  provider        = "prisma-client-js"
  engineType      = "library"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String            @id @default(cuid())
  name          String?
  email         String?           @unique
  emailVerified DateTime?
  image         String?
  role          Role              @default(STUDENT)
  status        UserStatus        @default(PENDING)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  trainerId     String?
  groupId       String?
  firstName     String?
  lastName      String?
  password      String?
  accounts      Account[]
  fileProgress  FileProgress[]
  trainerGroups Group[]           @relation("GroupTrainer")
  sessions      Session[]
  progress      StudentProgress[]
  group         Group?            @relation(fields: [groupId], references: [id])
  trainer       User?             @relation("TrainerStudents", fields: [trainerId], references: [id])
  students      User[]            @relation("TrainerStudents")
  createdModules Module[]         @relation("ModuleCreator")

  @@index([email])
  @@index([groupId])
  @@index([trainerId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Group {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  trainerId   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  trainer     User?    @relation("GroupTrainer", fields: [trainerId], references: [id])
  users       User[]
  groupModules GroupModule[]
}

model Module {
  id               String         @id @default(cuid())
  title            String
  description      String?
  objective        String?
  shortDescription String?
  thumbnailUrl     String?
  contentType      ContentType    @default(TEXT)
  creatorId        String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  creator          User?          @relation("ModuleCreator", fields: [creatorId], references: [id])
  exercises        Exercise[]
  fiches           Fiche[]
  files            UploadedFile[]
  groupModules     GroupModule[]

  @@index([creatorId])
}

model GroupModule {
  group     Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  groupId   String
  module    Module   @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  moduleId  String
  order     Int      @default(0)
  createdAt DateTime @default(now())

  @@id([groupId, moduleId])
  @@index([groupId])
  @@index([moduleId])
  @@index([order])
}

model Fiche {
  id          String     @id @default(cuid())
  title       String
  description String?
  objective   String?
  content     String
  part        Int        @default(1)
  order       Int        @default(0)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  moduleId    String
  exercises   Exercise[]
  module      Module     @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@index([moduleId])
  @@index([moduleId, order])
}

model Exercise {
  id        String            @id @default(cuid())
  type      String            @default("QCM")
  question  String
  options   String?
  answer    String
  order     Int               @default(0)
  level     Int               @default(1)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  ficheId   String?
  moduleId  String?
  module    Module?           @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  fiche     Fiche?            @relation(fields: [ficheId], references: [id], onDelete: Cascade)
  progress  StudentProgress[]

  @@index([ficheId])
  @@index([moduleId])
}

model StudentProgress {
  id          String    @id @default(cuid())
  isCompleted Boolean   @default(false)
  score       Int?
  attempts    Int       @default(0)
  lastAnswer  String?
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  userId      String
  exerciseId  String
  exercise    Exercise  @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, exerciseId])
  @@index([userId])
  @@index([exerciseId])
}

model FileProgress {
  id          String       @id @default(cuid())
  isCompleted Boolean      @default(false)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  userId      String
  fileId      String
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  file        UploadedFile @relation(fields: [fileId], references: [id], onDelete: Cascade)

  @@unique([userId, fileId])
  @@index([userId])
  @@index([fileId])
}

model UploadedFile {
  id            String         @id @default(cuid())
  filename      String
  originalName  String
  mimeType      String
  size          Int
  category      String         @default("COURS")
  path          String
  extractedText String?
  isProcessed   Boolean        @default(false)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  moduleId      String?
  progress      FileProgress[]
  module        Module?        @relation(fields: [moduleId], references: [id])

  @@index([moduleId])
  @@index([category])
}

model Invitation {
  id        String   @id @default(cuid())
  email     String   @unique
  lastName  String?
  firstName String?
  role      Role     @default(TRAINER)
  status    String   @default("PENDING")
  token     String   @unique @default(cuid())
  expiresAt DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
  @@index([token])
}

enum Role {
  ADMIN
  TRAINER
  STUDENT
}

enum UserStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ContentType {
  TEXT
  PRESENTATION
  AUDIO
}
